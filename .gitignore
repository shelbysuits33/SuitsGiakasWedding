# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# ssh keys — never commit these
id_ed25519*
id_rsa*
id_ecdsa*
*.key

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local editor / tooling config
.claude/

# original design source images (kept locally, re-derive assets as needed)
design-assets/

# typescript
*.tsbuildinfo
next-env.d.ts
